@{
    ViewData["Title"] = "Không tìm thấy trang";
    var statusCode = ViewBag.StatusCode as int? ?? 404;
}

<div class="not-found-wrap text-center py-5">
    <div class="not-found-card brand-form-card mx-auto p-4 p-md-5">
        <p class="not-found-code brand-title mb-2">@statusCode</p>
        <h1 class="fw-bold mb-3">TRANG KHÔNG TỒN TẠI</h1>
        <p class="text-muted mb-4">
            Đường dẫn bạn truy cập không có trên hệ thống, có thể đã bị xóa hoặc nhập sai URL.
        </p>
        <div class="d-flex flex-column flex-sm-row justify-content-center gap-2">
            <a asp-controller="Home" asp-action="Index" class="btn btn-brand px-4 py-2">
                <i class="bi bi-house-door"></i> Về trang chủ
            </a>
            <button type="button" class="btn btn-outline-brand px-4 py-2" onclick="history.back()">
                <i class="bi bi-arrow-left"></i> Quay lại
            </button>
        </div>
    </div>
</div>
