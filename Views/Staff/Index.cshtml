@{
    ViewData["Title"] = "Không gian làm việc - Nhân viên";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <h2 class="fw-bold"><i class="bi bi-person-badge"></i> WORKSPACE NHÂN VIÊN</h2>
            <p class="text-muted">Chào mừng bạn quay lại làm việc, <strong>@User.Identity?.Name</strong>!</p>
            <hr />
        </div>
    </div>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm border-0 h-100 border-start border-primary border-5">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-box-seam text-primary fs-1 me-3"></i>
                        <h4 class="card-title fw-bold mb-0">Xử lý Đơn hàng</h4>
                    </div>
                    <p class="card-text text-muted">Kiểm tra đơn hàng mới, cập nhật trạng thái đóng gói và theo dõi vận chuyển.</p>
                    <a asp-controller="Order" asp-action="Index" class="btn btn-primary fw-bold mt-2">Đi tới Đơn hàng</a>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
                <div class="card shadow-sm border-0 h-100 border-start border-success border-5">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-3">
                            <i class="bi bi-chat-dots text-success fs-1 me-3"></i>
                            <h4 class="card-title fw-bold mb-0">Hỗ trợ Khách hàng</h4>
                        </div>
                        <p class="card-text text-muted">Chat trực tuyến, giải đáp thắc mắc và hỗ trợ khách hàng đổi trả, khiếu nại.</p>
                        
                        <a asp-controller="Chat" asp-action="StaffList" class="btn btn-success fw-bold mt-2">
                            <i class="bi bi-chat-text"></i> Mở hộp thư CSKH
                        </a>
                    </div>
                </div>
            </div>

    </div>
</div>