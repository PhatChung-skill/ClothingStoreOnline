<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ClothingStoreWeb</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ClothingStoreWeb.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-light shadow-sm">
            <div class="container">
                <a class="navbar-brand fw-bold fs-3 text-primary" asp-controller="Home" asp-action="Index">CLOTHING STORE</a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto align-items-center">
                        @if (User?.Identity?.IsAuthenticated == true)
                        {
                            <li class="nav-item">
                                <span class="nav-link fw-bold text-dark me-3">Xin chào, @User.Identity.Name!</span>
                            </li>
                            
                            @if (User.IsInRole("Admin"))
                            {
                                <li class="nav-item">
                                    <a class="btn btn-outline-primary btn-sm me-2" asp-controller="Admin" asp-action="Index">Dashboard Admin</a>
                                </li>
                            }
                            else if (User.IsInRole("Staff"))
                            {
                                <li class="nav-item me-2">
                                    <a class="btn btn-outline-success btn-sm fw-bold" asp-controller="Chat" asp-action="StaffList">
                                        <i class="bi bi-headset"></i> Hỗ trợ Khách hàng
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="btn btn-outline-info btn-sm me-2 fw-bold text-dark" asp-controller="Staff" asp-action="Index">Workspace</a>
                                </li>
                            }
                            else 
                            {
                                <li class="nav-item me-2">
                                    <a class="btn btn-outline-success btn-sm fw-bold" asp-controller="Chat" asp-action="Index">
                                        <i class="bi bi-question-circle"></i> Thắc mắc / Khiếu nại
                                    </a>
                                </li>
                            }

                            <li class="nav-item">
                                <a class="btn btn-danger btn-sm" asp-controller="Auth" asp-action="Logout">Đăng xuất</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-bold" asp-controller="Auth" asp-action="Login">Đăng nhập</a>
                            </li>
                            <li class="nav-item ms-2">
                                <a class="btn btn-primary btn-sm text-white" asp-controller="Auth" asp-action="Register">Đăng ký</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - ClothingStoreWeb - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
