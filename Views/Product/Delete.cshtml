@model ClothingStoreWeb.Models.Product
@{
    ViewData["Title"] = "Xóa Sản phẩm";
}

<div class="row mt-4">
    <div class="col-md-6">
        <h2 class="text-danger">Xác nhận xóa Sản phẩm!</h2>
        <div class="alert alert-danger">
            Bạn có chắc chắn muốn xóa <strong>@Model.Name</strong> không? <br/>
            <strong>Lưu ý:</strong> Việc xóa sản phẩm sẽ xóa luôn toàn bộ Tồn kho (Size/Màu) và Hình ảnh liên quan.
        </div>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="ProductID" />
            <button type="submit" class="btn btn-danger">Đồng ý xóa</button>
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        </form>
    </div>
</div>