@model ClothingStoreWeb.ViewModels.CheckoutVM
@{
    ViewData["Title"] = "Thành toán đơn hàng";
}

<div class="container mt-5">
    <h2 class="mb-4 fw-bold brand-title">THÔNG TIN THANH TOÁN</h2>
    <hr />

    <form asp-action="Checkout" method="post">
        <div class="row">
            <div class="col-md-6">
                <h5 class="fw-bold mb-3 brand-section-title"><i class="bi bi-geo-alt"></i> Địa Chỉ Nhận Hàng</h5>
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label class="form-label fw-bold brand-form-label">Họ và tên người nhận</label>
                    <input asp-for="FullName" class="form-control form-control-lg brand-input" placeholder="Nhập đầy đủ họ và tên" />
                    <span asp-validation-for="FullName" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold brand-form-label">Số điện thoại liên hệ</label>
                    <input asp-for="Phone" class="form-control form-control-lg brand-input" placeholder="Nhập số điện thoại nhận hàng" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-bold brand-form-label">Địa chỉ giao hàng chi tiết</label>
                    <input asp-for="ShippingAddress" class="form-control form-control-lg brand-input" placeholder="Số nhà, tên đường, phường/xã, quận/huyện..." />
                    <span asp-validation-for="ShippingAddress" class="text-danger"></span>
                </div>
            </div>

            <div class="col-md-6">
                <h5 class="fw-bold mb-3 brand-section-title"><i class="bi bi-credit-card"></i> Phương Thức Thanh Toán (Demo)</h5>
                
                <div class="card mb-4 brand-payment-card">
                    <div class="card-body">
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="radio" asp-for="PaymentMethod" id="payCOD" value="COD" checked>
                            <label class="form-check-label fw-bold" for="payCOD">
                                <i class="bi bi-cash-coin brand-title"></i> Thanh toán tiền mặt khi nhận hàng (COD)
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" asp-for="PaymentMethod" id="payQR" value="QR_Transfer">
                            <label class="form-check-label fw-bold" for="payQR">
                                <i class="bi bi-qr-code-scan brand-title"></i> Chuyển khoản ngân hàng qua mã QR (Tĩnh)
                            </label>
                        </div>

                        <div class="alert mt-3 mb-0 small brand-muted-box">
                            <i class="bi bi-info-circle"></i> <strong>Lưu ý Demo:</strong> Nếu chọn QR_Transfer, hệ thống sẽ chốt đơn và hiển thị mã QR tài khoản ở màn hình tiếp theo để người dùng quét giả định.
                        </div>
                    </div>
                </div>

                <h5 class="fw-bold mb-3"><i class="bi bi-bag-check"></i> Tóm Tắt Đơn Hàng</h5>
                <ul class="list-group mb-3 shadow-sm">
                    @foreach (var item in (List<ClothingStoreWeb.Models.CartItem>)ViewBag.Cart)
                    {
                        <li class="list-group-item d-flex justify-content-between lh-sm">
                            <div>
                                <h6 class="my-0 fw-bold">@item.ProductName</h6>
                                <small class="text-muted">Màu: @item.Color | Size: @item.Size | SL: @item.Quantity</small>
                            </div>
                            <span class="text-muted">@item.TotalPrice.ToString("N0") đ</span>
                        </li>
                    }
                    <li class="list-group-item d-flex justify-content-between bg-light">
                        <span class="fw-bold text-danger fs-5">TỔNG CỘNG:</span>
                        <strong class="text-danger fs-5">@ViewBag.TotalAmount.ToString("N0") đ</strong>
                    </li>
                </ul>

                <button type="submit" class="btn btn-brand btn-lg w-100 py-3 fw-bold shadow">XÁC NHẬN ĐẶT HÀNG NGAY</button>
            </div>
        </div>
    </form>
</div>