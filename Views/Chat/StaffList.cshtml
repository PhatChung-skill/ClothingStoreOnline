@{
    ViewData["Title"] = "Quản lý Chat Khách hàng";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-chat-left-text"></i> HỘP THƯ HỖ TRỢ</h2>
        <a asp-controller="Staff" asp-action="Index" class="btn btn-secondary">Quay lại Workspace</a>
    </div>

    <div class="list-group shadow-sm">
        @foreach (var item in ViewBag.ChatList)
        {
            <a asp-action="StaffDetails" asp-route-id="@item.User.UserID" class="list-group-item list-group-item-action p-3">
                <div class="d-flex w-100 justify-content-between">
                    <h5 class="mb-1 fw-bold @(item.UnreadCount > 0 ? "text-primary" : "")">
                        @(string.IsNullOrEmpty(item.User.FullName) ? item.User.Username : item.User.FullName)
                        @if (item.UnreadCount > 0)
                        {
                            <span class="badge bg-danger rounded-pill ms-2">@item.UnreadCount tin mới</span>
                        }
                    </h5>
                    <small class="text-muted">@item.LastMessage.SentAt.ToString("HH:mm dd/MM/yyyy")</small>
                </div>
                <p class="mb-1 text-truncate text-muted" style="max-width: 80%;">
                    @(item.LastMessage.IsFromStaff ? "Bạn: " : "")@item.LastMessage.MessageText
                </p>
                <small class="text-muted">Tài khoản: @item.User.Username</small>
            </a>
        }
        @if (((IEnumerable<dynamic>)ViewBag.ChatList).Count() == 0)
        {
            <div class="text-center text-muted p-5 border rounded bg-light">Chưa có khách hàng nào gửi yêu cầu hỗ trợ.</div>
        }
    </div>
</div>