@model IEnumerable<ClothingStoreWeb.Models.Order>
@{
    ViewData["Title"] = "Quản lý Đơn hàng";
}

<div class="mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>DANH SÁCH ĐƠN HÀNG</h2>
        <a asp-controller="Admin" asp-action="Index" class="btn btn-secondary">Quay lại Dashboard</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <table class="table table-hover border">
        <thead class="table-dark">
            <tr>
                <th>Mã Đơn</th>
                <th>Ngày đặt</th>
                <th>Khách hàng</th>
                <th>Tổng tiền</th>
                <th>Trạng thái</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>#@item.OrderID</td>
                    <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        @if (item.User != null)
                        {
                            <span class="fw-bold">@(string.IsNullOrEmpty(item.User.FullName) ? item.User.Username : item.User.FullName)</span>
                            <br />
                            <small class="text-muted" style="font-size: 11px;">Tài khoản: @item.User.Username</small>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Khách vãng lai (Mua nhanh)</span>
                        }
                    </td>
                    <td class="fw-bold text-primary">@item.TotalAmount.ToString("N0") đ</td>
                    <td>
                        @if (item.Status == "Pending") { <span class="badge bg-warning text-dark">Chờ duyệt</span> }
                        else if (item.Status == "Shipping") { <span class="badge bg-info">Đang giao</span> }
                        else if (item.Status == "Completed") { <span class="badge bg-success">Hoàn thành</span> }
                        else { <span class="badge bg-danger">Đã hủy</span> }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.OrderID" class="btn btn-sm btn-outline-primary">Chi tiết</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>