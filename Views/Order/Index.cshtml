@model IEnumerable<ClothingStoreWeb.Models.Order>
@{
    ViewData["Title"] = "Quản lý Đơn hàng";
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
}

<div class="mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>DANH SÁCH ĐƠN HÀNG</h2>
        @if (User.IsInRole("Admin"))
        {
            <a asp-controller="Admin" asp-action="Index" class="btn btn-secondary">Quay lại Dashboard Admin</a>
        }
        else if (User.IsInRole("Staff"))
        {
            <a asp-controller="Staff" asp-action="Index" class="btn btn-secondary">Quay lại Workspace</a>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <form method="get" class="mb-4 bg-light p-3 border rounded shadow-sm">
        <div class="row g-3">
            <div class="col-md-5">
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Tìm Mã Đơn, Khách hàng..." style="font-size: 0.9rem;" />
                </div>
            </div>
            <div class="col-md-4">
                <select name="status" class="form-select" style="font-size: 0.9rem;" onchange="this.form.submit()">
                    <option value="">-- Tất cả trạng thái --</option>
                    <option value="Pending" selected="@(ViewBag.Status == "Pending")">Chờ duyệt</option>
                    <option value="Shipping" selected="@(ViewBag.Status == "Shipping")">Đang giao</option>
                    <option value="Completed" selected="@(ViewBag.Status == "Completed")">Hoàn thành</option>
                    <option value="Cancelled" selected="@(ViewBag.Status == "Cancelled")">Đã hủy</option>
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-dark w-100 fw-bold" style="font-size: 0.9rem;">Lọc đơn</button>
                @if (!string.IsNullOrEmpty(ViewBag.Search) || !string.IsNullOrEmpty(ViewBag.Status))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center justify-content-center" title="Xóa bộ lọc"><i class="bi bi-x-lg"></i></a>
                }
            </div>
        </div>
    </form>

    <table class="table table-hover border">
        <thead class="table-dark">
            <tr>
                <th>Mã Đơn</th>
                <th>Ngày đặt</th>
                <th>Khách hàng</th>
                <th>Tổng tiền</th>
                <th>Trạng thái</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>#@item.OrderID</td>
                    <td>@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        <span class="fw-bold">@item.ReceiverName</span>
                        <br />
                        @if (item.User != null)
                        {
                            <small class="text-muted" style="font-size: 11px;">Tài khoản: @item.User.Username</small>
                        }
                        else
                        {
                            <span class="badge bg-secondary" style="font-size: 10px;">Khách vãng lai</span>
                        }
                    </td>
                    <td class="fw-bold text-primary">@item.TotalAmount.ToString("N0") đ</td>
                    <td>
                        @if (item.Status == "Pending") { <span class="badge bg-warning text-dark">Chờ duyệt</span> }
                        else if (item.Status == "Shipping") { <span class="badge bg-info">Đang giao</span> }
                        else if (item.Status == "Completed") { <span class="badge bg-success">Hoàn thành</span> }
                        else { <span class="badge bg-danger">Đã hủy</span> }
                    </td>
                    <td>
                        <a asp-action="Details" asp-route-id="@item.OrderID" class="btn btn-sm btn-outline-primary">Chi tiết</a>

                        @if (User.IsInRole("Admin") && (item.Status == "Completed" || item.Status == "Cancelled"))
                        {
                            <form asp-action="Delete" method="post" class="d-inline">
                                <input type="hidden" name="id" value="@item.OrderID" />
                                <button type="submit" class="btn btn-sm btn-outline-danger ms-1" onclick="return confirm('Bạn có chắc chắn muốn xóa vĩnh viễn đơn hàng #@item.OrderID này cho gọn danh sách không?')">
                                    <i class="bi bi-trash"></i> Xóa
                                </button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (totalPages > 1)
    {
        <nav aria-label="Phan trang don hang">
            <ul class="pagination">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-search="@ViewBag.Search" asp-route-status="@ViewBag.Status">Trước</a>
                </li>
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-search="@ViewBag.Search" asp-route-status="@ViewBag.Status">@i</a>
                    </li>
                }
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-search="@ViewBag.Search" asp-route-status="@ViewBag.Status">Sau</a>
                </li>
            </ul>
        </nav>
    }
</div>