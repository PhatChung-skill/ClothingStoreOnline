@model IEnumerable<ClothingStoreWeb.Models.User>
@{
    ViewData["Title"] = "Quản lý Người dùng";
}

<div class="mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-people-fill"></i> QUẢN LÝ TÀI KHOẢN NGƯỜI DÙNG</h2>
        <a asp-controller="Admin" asp-action="Index" class="btn btn-secondary">Quay lại Dashboard</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <table class="table table-bordered table-hover align-middle shadow-sm">
        <thead class="table-dark text-center">
            <tr>
                <th>Tên Đăng Nhập</th>
                <th>Họ và Tên</th>
                <th>Email</th>
                <th>Số Điện Thoại</th>
                <th style="width: 180px;">Phân Quyền (Role)</th>
                <th style="width: 150px;">Trạng Thái</th>
                <th style="width: 150px;">Thao Tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr class="@(user.IsLocked ? "table-danger text-muted" : "")">
                    <td class="fw-bold">@user.Username</td>
                    <td>@(user.FullName ?? "Chưa cập nhật")</td>
                    <td>@user.Email</td>
                    <td>@(user.Phone ?? "Chưa cập nhật")</td>
                    <td>
                        <form asp-action="ChangeRole" method="post">
                            <input type="hidden" name="id" value="@user.UserID" />
                            <select name="newRole" class="form-select form-select-sm fw-bold text-center" onchange="this.form.submit()">
                                <option value="Customer" selected="@(user.Role == "Customer")">Customer</option>
                                <option value="Staff" selected="@(user.Role == "Staff")">Staff</option>
                                <option value="Admin" selected="@(user.Role == "Admin")">Admin</option>
                            </select>
                        </form>
                    </td>
                    <td class="text-center">
                        @if (user.IsLocked)
                        {
                            <span class="badge bg-danger"><i class="bi bi-lock-fill"></i> Đang bị khóa</span>
                        }
                        else
                        {
                            <span class="badge bg-success"><i class="bi bi-shield-check"></i> Hoạt động</span>
                        }
                    </td>
                    <td class="text-center">
                        <form asp-action="ToggleLock" method="post">
                            <input type="hidden" name="id" value="@user.UserID" />
                            @if (user.IsLocked)
                            {
                                <button type="submit" class="btn btn-sm btn-success w-100 fw-bold">
                                    <i class="bi bi-unlock"></i> Mở khóa
                                </button>
                            }
                            else
                            {
                                <button type="submit" class="btn btn-sm btn-outline-danger w-100 fw-bold" onclick="return confirm('Bạn có chắc muốn khóa tài khoản này?')">
                                    <i class="bi bi-lock"></i> Khóa lại
                                </button>
                            }
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>