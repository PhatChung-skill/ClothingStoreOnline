@model IEnumerable<ClothingStoreWeb.Models.User>
@{
    ViewData["Title"] = "Quản lý Người dùng";
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
}

<div class="mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-people-fill"></i> QUẢN LÝ TÀI KHOẢN NGƯỜI DÙNG</h2>
        <a asp-controller="Admin" asp-action="Index" class="btn btn-secondary">Quay lại Dashboard</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <form method="get" class="mb-4 bg-light p-3 border rounded shadow-sm">
        <div class="row g-3">
            <div class="col-md-5">
                <div class="input-group">
                    <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Tìm tên đăng nhập, họ tên, email, SĐT..." style="font-size: 0.9rem;" />
                </div>
            </div>
            <div class="col-md-4">
                <select name="role" class="form-select" style="font-size: 0.9rem;" onchange="this.form.submit()">
                    <option value="">-- Tất cả vai trò (Role) --</option>
                    <option value="Customer" selected="@(ViewBag.Role == "Customer")">Customer (Khách hàng)</option>
                    <option value="Staff" selected="@(ViewBag.Role == "Staff")">Staff (Nhân viên)</option>
                    <option value="Admin" selected="@(ViewBag.Role == "Admin")">Admin (Quản trị viên)</option>
                </select>
            </div>
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-dark w-100 fw-bold" style="font-size: 0.9rem;">Lọc tài khoản</button>
                @if (!string.IsNullOrEmpty(ViewBag.Search) || !string.IsNullOrEmpty(ViewBag.Role))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary d-flex align-items-center justify-content-center" title="Xóa bộ lọc"><i class="bi bi-x-lg"></i></a>
                }
            </div>
        </div>
    </form>

    <table class="table table-bordered table-hover align-middle shadow-sm">
        <thead class="table-dark text-center">
            <tr>
                <th>Tên Đăng Nhập</th>
                <th>Họ và Tên</th>
                <th>Email</th>
                <th>Số Điện Thoại</th>
                <th style="width: 180px;">Phân Quyền (Role)</th>
                <th style="width: 150px;">Trạng Thái</th>
                <th style="width: 150px;">Thao Tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr class="@(user.IsLocked ? "table-danger text-muted" : "")">
                    <td class="fw-bold">@user.Username</td>
                    <td>@(user.FullName ?? "Chưa cập nhật")</td>
                    <td>@user.Email</td>
                    <td>@(user.Phone ?? "Chưa cập nhật")</td>
                    <td>
                        <form asp-action="ChangeRole" method="post">
                            <input type="hidden" name="id" value="@user.UserID" />
                            <select name="newRole" class="form-select form-select-sm fw-bold text-center" onchange="this.form.submit()">
                                <option value="Customer" selected="@(user.Role == "Customer")">Customer</option>
                                <option value="Staff" selected="@(user.Role == "Staff")">Staff</option>
                                <option value="Admin" selected="@(user.Role == "Admin")">Admin</option>
                            </select>
                        </form>
                    </td>
                    <td class="text-center">
                        @if (user.IsLocked)
                        {
                            <span class="badge bg-danger"><i class="bi bi-lock-fill"></i> Đang bị khóa</span>
                        }
                        else
                        {
                            <span class="badge bg-success"><i class="bi bi-shield-check"></i> Hoạt động</span>
                        }
                    </td>
                    <td class="text-center">
                        <form asp-action="ToggleLock" method="post">
                            <input type="hidden" name="id" value="@user.UserID" />
                            @if (user.IsLocked)
                            {
                                <button type="submit" class="btn btn-sm btn-success w-100 fw-bold">
                                    <i class="bi bi-unlock"></i> Mở khóa
                                </button>
                            }
                            else
                            {
                                <button type="submit" class="btn btn-sm btn-outline-danger w-100 fw-bold" onclick="return confirm('Bạn có chắc muốn khóa tài khoản này?')">
                                    <i class="bi bi-lock"></i> Khóa lại
                                </button>
                            }
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (totalPages > 1)
    {
        <nav aria-label="Phan trang nguoi dung">
            <ul class="pagination">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-search="@ViewBag.Search" asp-route-role="@ViewBag.Role">Trước</a>
                </li>
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@i" asp-route-search="@ViewBag.Search" asp-route-role="@ViewBag.Role">@i</a>
                    </li>
                }
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-search="@ViewBag.Search" asp-route-role="@ViewBag.Role">Sau</a>
                </li>
            </ul>
        </nav>
    }
</div>