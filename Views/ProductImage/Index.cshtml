@model IEnumerable<ClothingStoreWeb.Models.ProductImage>
@{
    ViewData["Title"] = "Quản lý hình ảnh";
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
}

<div class="mt-4">
    <h2>Quản lý hình ảnh cho: <span class="text-primary">@ViewBag.ProductName</span></h2>
    <hr />

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="card mb-4">
        <div class="card-body">
            <h5 class="card-title">Thêm ảnh mới (Tối đa 3 ảnh)</h5>
            <form asp-action="Upload" method="post" enctype="multipart/form-data" class="row g-3">
                <input type="hidden" name="productId" value="@ViewBag.ProductId" />
                <div class="col-auto">
                    <input type="file" name="file" class="form-control" accept="image/*" required />
                </div>
                <div class="col-auto">
                    <button type="submit" class="btn btn-primary">Tải lên</button>
                </div>
            </form>
        </div>
    </div>

    <div class="row">
        @foreach (var img in Model)
        {
            <div class="col-md-4 mb-3 text-center">
                <div class="card">
                    <img src="@img.ImageUrl" class="card-img-top" style="height: 250px; object-fit: cover;">
                    <div class="card-body">
                        @if (img.IsThumbnail)
                        {
                            <span class="badge bg-success mb-2">Ảnh đại diện</span>
                        }
                        <form asp-action="Delete" method="post">
                            <input type="hidden" name="imageId" value="@img.ImageID" />
                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Xóa ảnh này?')">Xóa ảnh</button>
                        </form>
                    </div>
                </div>
            </div>
        }
        @if (!Model.Any())
        {
            <p class="text-muted">Chưa có hình ảnh nào cho sản phẩm này.</p>
        }
    </div>

    @if (totalPages > 1)
    {
        <nav aria-label="Phan trang hinh anh" class="mb-3">
            <ul class="pagination">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-productId="@ViewBag.ProductId" asp-route-page="@(currentPage - 1)">Truoc</a>
                </li>
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-productId="@ViewBag.ProductId" asp-route-page="@i">@i</a>
                    </li>
                }
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-productId="@ViewBag.ProductId" asp-route-page="@(currentPage + 1)">Sau</a>
                </li>
            </ul>
        </nav>
    }

    <a asp-controller="Product" asp-action="Index" class="btn btn-secondary mt-3">Quay lại danh sách sản phẩm</a>
</div>