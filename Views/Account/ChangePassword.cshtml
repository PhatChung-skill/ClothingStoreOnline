@model ClothingStoreWeb.ViewModels.ChangePasswordVM
@{
    ViewData["Title"] = "Đổi mật khẩu";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-6 col-lg-5">
        <div class="brand-form-card p-4 p-md-5">
            <h3 class="text-center fw-bold brand-title mb-2">ĐỔI MẬT KHẨU</h3>
            <p class="text-center text-muted mb-4">Xác nhận thông tin tài khoản trước khi đổi mật khẩu</p>

            <form asp-action="ChangePassword" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label class="brand-form-label mb-2">Tên đăng nhập</label>
                    <input asp-for="Username" class="form-control brand-input" />
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="brand-form-label mb-2">Email</label>
                    <input asp-for="Email" class="form-control brand-input" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="brand-form-label mb-2">Mật khẩu hiện tại</label>
                    <div class="password-input-group">
                        <input asp-for="CurrentPassword" class="form-control brand-input" type="password" />
                        <button type="button" class="password-toggle-btn" aria-label="Hiện mật khẩu">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="brand-form-label mb-2">Mật khẩu mới</label>
                    <div class="password-input-group">
                        <input asp-for="NewPassword" class="form-control brand-input" type="password" />
                        <button type="button" class="password-toggle-btn" aria-label="Hiện mật khẩu">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="brand-form-label mb-2">Xác nhận mật khẩu mới</label>
                    <div class="password-input-group">
                        <input asp-for="ConfirmNewPassword" class="form-control brand-input" type="password" />
                        <button type="button" class="password-toggle-btn" aria-label="Hiện mật khẩu">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-brand w-100 py-2 mb-2">Cập nhật mật khẩu</button>
                <a asp-action="Profile" class="btn btn-outline-brand w-100 py-2">Quay lại tài khoản</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
