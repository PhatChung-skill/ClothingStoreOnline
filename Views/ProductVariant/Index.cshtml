@model IEnumerable<ClothingStoreWeb.Models.ProductVariant>
@{
    ViewData["Title"] = "Quản lý tồn kho";
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
}

<div class="mt-4">
    <h2>Biến thể & Tồn kho: <span class="text-primary">@ViewBag.ProductName</span></h2>
    <hr />

    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-3">
        <a asp-action="Create" asp-route-productId="@ViewBag.ProductId" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Thêm Size/Màu mới
        </a>
        
        <form method="get" class="d-flex gap-2 align-items-center" style="max-width: 400px; width: 100%;">
            <input type="hidden" name="productId" value="@ViewBag.ProductId" />
            <div class="input-group">
                <span class="input-group-text bg-white"><i class="bi bi-search text-muted"></i></span>
                <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Tìm màu sắc hoặc kích cỡ..." style="font-size: 0.9rem;" />
                @if (!string.IsNullOrEmpty(ViewBag.Search))
                {
                    <a asp-action="Index" asp-route-productId="@ViewBag.ProductId" class="btn btn-outline-secondary d-flex align-items-center justify-content-center" title="Xóa lọc"><i class="bi bi-x-lg"></i></a>
                }
                <button type="submit" class="btn btn-dark fw-bold">Tìm</button>
            </div>
        </form>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <table class="table table-bordered table-hover text-center">
        <thead class="table-dark">
            <tr>
                <th>Màu sắc</th>
                <th>Kích cỡ (Size)</th>
                <th>Số lượng tồn</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Color</td>
                    <td><span class="badge bg-secondary">@item.Size</span></td>
                    <td class="fw-bold @(item.StockQuantity <= 5 ? "text-danger" : "")">
                        @item.StockQuantity
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.VariantID" class="btn btn-sm btn-warning">Sửa</a>
                        <form asp-action="Delete" method="post" style="display:inline-block;">
                            <input type="hidden" name="variantId" value="@item.VariantID" />
                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Xóa biến thể này?')">Xóa</button>
                        </form>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="4" class="text-muted">Chưa có biến thể nào. Hãy thêm Size và Màu sắc.</td>
                </tr>
            }
        </tbody>
    </table>

    @if (totalPages > 1)
    {
        <nav aria-label="Phan trang bien the" class="mb-3">
            <ul class="pagination">
                <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-productId="@ViewBag.ProductId" asp-route-page="@(currentPage - 1)" asp-route-search="@ViewBag.Search">Trước</a>
                </li>
                @for (int i = 1; i <= totalPages; i++)
                {
                    <li class="page-item @(i == currentPage ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-productId="@ViewBag.ProductId" asp-route-page="@i" asp-route-search="@ViewBag.Search">@i</a>
                    </li>
                }
                <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                    <a class="page-link" asp-action="Index" asp-route-productId="@ViewBag.ProductId" asp-route-page="@(currentPage + 1)" asp-route-search="@ViewBag.Search">Sau</a>
                </li>
            </ul>
        </nav>
    }

    <a asp-controller="Product" asp-action="Index" class="btn btn-secondary">Quay lại danh sách sản phẩm</a>
</div>