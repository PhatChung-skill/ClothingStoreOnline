@model ClothingStoreWeb.ViewModels.ResetPasswordVM
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-5">
        <div class="brand-form-card p-4 p-md-5">
            <h3 class="text-center fw-bold brand-title mb-2">ĐẶT LẠI MẬT KHẨU</h3>
            <p class="text-center text-muted mb-4">Nhập mã OTP và mật khẩu mới</p>

            <partial name="_OtpAlerts" />

            <form asp-action="ResetPassword" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label class="brand-form-label mb-2">Email</label>
                    <input asp-for="Email" class="form-control brand-input" readonly />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="brand-form-label mb-2">Mã OTP (6 số)</label>
                    <input asp-for="OtpCode" class="form-control brand-input otp-input text-center fw-bold fs-4"
                           maxlength="6" inputmode="numeric" pattern="\d{6}" placeholder="000000" autocomplete="one-time-code" />
                    <span asp-validation-for="OtpCode" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="brand-form-label mb-2">Mật khẩu mới</label>
                    <div class="password-input-group">
                        <input asp-for="NewPassword" class="form-control brand-input" type="password" />
                        <button type="button" class="password-toggle-btn" aria-label="Hiện mật khẩu">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="brand-form-label mb-2">Xác nhận mật khẩu mới</label>
                    <div class="password-input-group">
                        <input asp-for="ConfirmPassword" class="form-control brand-input" type="password" />
                        <button type="button" class="password-toggle-btn" aria-label="Hiện mật khẩu">
                            <i class="bi bi-eye"></i>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-brand w-100 py-2 mb-3">Đặt lại mật khẩu</button>
            </form>

            <form asp-action="ResendForgotPasswordOtp" method="post" class="text-center">
                <input type="hidden" name="email" value="@Model.Email" />
                <button type="submit" class="btn btn-link brand-link p-0">Gửi lại mã OTP</button>
            </form>

            <div class="mt-3 text-center">
                <a class="brand-link" asp-action="Login">Quay lại đăng nhập</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
