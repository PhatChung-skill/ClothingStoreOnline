@model ClothingStoreWeb.ViewModels.RegisterVM
@{
    ViewData["Title"] = "Đăng ký";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 col-lg-5">
        <div class="brand-form-card p-4 p-md-5">
        <h3 class="text-center fw-bold brand-title mb-4">ĐĂNG KÝ</h3>
        <form asp-action="Register" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label class="brand-form-label mb-2">Tên đăng nhập</label>
                <input asp-for="Username" class="form-control brand-input" />
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="brand-form-label mb-2">Email</label>
                <input asp-for="Email" class="form-control brand-input" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="brand-form-label mb-2">Mật khẩu</label>
                <div class="password-input-group">
                    <input asp-for="Password" class="form-control brand-input" type="password" />
                    <button type="button" class="password-toggle-btn" aria-label="Hiện mật khẩu">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="brand-form-label mb-2">Xác nhận mật khẩu</label>
                <div class="password-input-group">
                    <input asp-for="ConfirmPassword" class="form-control brand-input" type="password" />
                    <button type="button" class="password-toggle-btn" aria-label="Hiện mật khẩu">
                        <i class="bi bi-eye"></i>
                    </button>
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-brand w-100 py-2">Đăng ký</button>

            <div class="mt-3 text-center">
                <a class="brand-link" asp-action="Login">Đã có tài khoản? Đăng nhập</a>
            </div>

        </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
