@model ClothingStoreWeb.ViewModels.LoginVM
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5 col-lg-4">
        <div class="brand-form-card p-4 p-md-5">
        <h3 class="text-center fw-bold brand-title mb-4">ĐĂNG NHẬP</h3>
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">@TempData["Success"]</div>
        }
        <form asp-action="Login" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="mb-3">
                <label class="brand-form-label mb-2">Tên đăng nhập</label>
                <input asp-for="Username" class="form-control brand-input" />
                <span asp-validation-for="Username" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="brand-form-label mb-2">Mật khẩu</label>
                <input asp-for="Password" class="form-control brand-input" />
                <span asp-validation-for="Password" class="text-danger"></span>
            </div>
            <button type="submit" class="btn btn-brand w-100 py-2">Đăng nhập</button>
            <div class="mt-3 text-center">
                <a class="brand-link" asp-action="Register">Chưa có tài khoản? Đăng ký ngay</a>
            </div>
        </form>
        </div>
    </div>
</div>